# Keep shell scripts, the systemd unit, and config files LF-only — CRLF would break the
# shebang/parsing when they're packaged into the .deb/.rpm/.apk or run on Linux.
*.sh        text eol=lf
*.service   text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
Makefile    text eol=lf

# Embedded font binaries — never apply line-ending or text filters; CRLF
# conversion would corrupt the TTFs that go:embed bakes into the binary.
*.ttf       binary
